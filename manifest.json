{
  "manifest_version": 3,
  "name": "Email Writer Chrome Extension",
  "version": "1.1",
  "description": "Improve Gmail drafts with AI-suggested writing styles via OpenRouter",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.google.com/*",
    "https://openrouter.ai/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Email Writer Chrome Extension"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["contentScript.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
