{
  "manifest_version": 3,
  "name": "Email Writer Chrome Extension",
  "homepage_url": "https://github.com/lucamussari/email-writer-chrome-extension",
  "version": "1.3",
  "description": "Generate Gmail replies from your instructions using thread context via OpenRouter",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.google.com/*",
    "https://openrouter.ai/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Email Writer Chrome Extension"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["contentScript.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon16.png", "icon48.png"],
      "matches": ["https://mail.google.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
